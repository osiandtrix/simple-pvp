{
  "$schema": "https://raw.githubusercontent.com/nicerapp/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Simple Companion PvP",
  "version": "1.2.7",
  "identifier": "com.simple-companion-pvp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Simple Companion PvP",
        "width": 500,
        "height": 750,
        "minWidth": 500,
        "minHeight": 200,
        "resizable": true
      }
    ],
    "security": {}
  },
  "plugins": {}
}
